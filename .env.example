# Copy this file to .env.local

# WalletConnect Project ID (optional but recommended)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Arc Testnet RPC + Explorer
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_ARC_EXPLORER_API=https://testnet.arcscan.app/api

# Tokens (USDC only)
NEXT_PUBLIC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Contracts
NEXT_PUBLIC_FAUCET_CONTRACT=0xd9145CCE52D386f254917e481eB44e9943F39138
NEXT_PUBLIC_DAILY_CONTRACT=0xf8e81D47203A594245E36C48e151709F0C19fBe8
